generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserCategory {
  comun
  especial
  plata
  oro
  platino
}

enum UserStatus {
  pendiente
  aprobado
  suspendido
  bloqueado
}

enum AuctionStatus {
  programada
  abierta
  cerrada
  finalizada
}

enum AuctionCategory {
  comun
  especial
  plata
  oro
  platino
}

enum Currency {
  ARS
  USD
}

enum ItemStatus {
  disponible
  en_subasta
  vendido
}

enum PaymentType {
  cuenta_bancaria_nacional
  cuenta_bancaria_extranjera
  tarjeta_credito_nacional
  tarjeta_credito_internacional
  cheque_certificado
}

enum SubmissionStatus {
  pendiente_empresa
  interesada
  rechazada_empresa
  precio_propuesto
  aceptada_usuario
  rechazada_usuario
}

enum PurchaseStatus {
  pendiente_pago
  pagado
  multa_aplicada
  derivado_justicia
}

model User {
  id                String        @id @default(cuid())
  nombre            String
  apellido          String
  email             String?       @unique
  passwordHash      String?
  docFrenteUrl      String
  docDorsoUrl       String
  domicilioLegal    String
  paisOrigen        String
  categoria         UserCategory  @default(comun)
  status            UserStatus    @default(pendiente)
  registrationToken String?
  tokenExpiresAt    DateTime?
  isAdmin           Boolean       @default(false)
  cuentaCobro       String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  paymentMethods PaymentMethod[]
  bids           Puja[]
  participants   AuctionParticipant[]
  messages       Mensaje[]
  submissions    ItemSubmission[]
  purchases      Purchase[]
  ownedItems     Item[]          @relation("CurrentOwner")

  @@map("users")
}

model PaymentMethod {
  id             String      @id @default(cuid())
  userId         String
  user           User        @relation(fields: [userId], references: [id])
  tipo           PaymentType
  moneda         Currency
  banco          String?
  numeroCuenta   String?
  swift          String?
  numeroTarjeta  String?
  titularTarjeta String?
  vencimiento    String?
  montoGarantia  Decimal?    @db.Decimal(12, 2)
  verificado     Boolean     @default(false)
  activo         Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@map("payment_methods")
}

model Rematador {
  id        String    @id @default(cuid())
  nombre    String
  apellido  String
  matricula String    @unique
  email     String?
  activo    Boolean   @default(true)
  createdAt DateTime  @default(now())

  auctions Auction[]

  @@map("rematadores")
}

model Auction {
  id              String          @id @default(cuid())
  titulo          String
  descripcion     String?
  fechaHora       DateTime
  ubicacion       String
  categoria       AuctionCategory
  moneda          Currency
  status          AuctionStatus   @default(programada)
  esColeccion     Boolean         @default(false)
  nombreColeccion String?
  rematadorId     String
  rematador       Rematador       @relation(fields: [rematadorId], references: [id])
  currentItemId   String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  items        Item[]
  bids         Puja[]
  participants AuctionParticipant[]

  @@map("auctions")
}

model Item {
  id                   String     @id @default(cuid())
  numeroPieza          String     @unique
  descripcion          String
  precioBase           Decimal    @db.Decimal(12, 2)
  status               ItemStatus @default(disponible)
  currentOwnerId       String
  currentOwner         User       @relation("CurrentOwner", fields: [currentOwnerId], references: [id])
  auctionId            String?
  auction              Auction?   @relation(fields: [auctionId], references: [id])
  ordenEnSubasta       Int?
  esObraDeArte         Boolean    @default(false)
  artista              String?
  fechaObra            String?
  historia             String?
  cantidadElementos    Int        @default(1)
  descripcionElementos String?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  images       ItemImage[]
  bids         Puja[]
  insurance    Seguro?
  ubicacion    ItemUbicacion?
  submissionId String?        @unique
  submission   ItemSubmission? @relation(fields: [submissionId], references: [id])
  purchase     Purchase?

  @@map("items")
}

model ItemImage {
  id     String @id @default(cuid())
  itemId String
  item   Item   @relation(fields: [itemId], references: [id])
  url    String
  orden  Int    @default(0)

  @@map("item_images")
}

model Puja {
  id         String   @id @default(cuid())
  auctionId  String
  auction    Auction  @relation(fields: [auctionId], references: [id])
  itemId     String
  item       Item     @relation(fields: [itemId], references: [id])
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  monto      Decimal  @db.Decimal(12, 2)
  moneda     Currency
  confirmada Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([itemId, createdAt])
  @@map("pujas")
}

model AuctionParticipant {
  id        String   @id @default(cuid())
  auctionId String
  auction   Auction  @relation(fields: [auctionId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  isActive  Boolean  @default(true)
  joinedAt  DateTime @default(now())
  leftAt    DateTime?

  @@unique([auctionId, userId])
  @@map("auction_participants")
}

model ItemSubmission {
  id                   String           @id @default(cuid())
  userId               String
  user                 User             @relation(fields: [userId], references: [id])
  descripcion          String
  datosHistoricos      String?
  declaracionPropiedad Boolean          @default(false)
  origenLicito         Boolean          @default(false)
  status               SubmissionStatus @default(pendiente_empresa)
  precioBaseOfrecido   Decimal?         @db.Decimal(12, 2)
  comisionesInfo       String?
  motivoRechazo        String?
  gastoDevolucion      Decimal?         @db.Decimal(12, 2)
  cuentaCobro          String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  images SubmissionImage[]
  item   Item?

  @@map("item_submissions")
}

model SubmissionImage {
  id           String         @id @default(cuid())
  submissionId String
  submission   ItemSubmission @relation(fields: [submissionId], references: [id])
  url          String
  orden        Int            @default(0)

  @@map("submission_images")
}

model Seguro {
  id             String    @id @default(cuid())
  itemId         String    @unique
  item           Item      @relation(fields: [itemId], references: [id])
  polizaNumero   String
  polizaGrupoId  String?
  valorAsegurado Decimal   @db.Decimal(12, 2)
  beneficiarioId String
  proveedor      String
  contacto       String?
  vencimiento    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("seguros")
}

model ItemUbicacion {
  id        String   @id @default(cuid())
  itemId    String   @unique
  item      Item     @relation(fields: [itemId], references: [id])
  deposito  String
  sector    String?
  notas     String?
  updatedAt DateTime @updatedAt

  @@map("item_ubicaciones")
}

model Mensaje {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  asunto    String
  cuerpo    String
  tipo      String
  leido     Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("mensajes")
}

model Purchase {
  id                  String         @id @default(cuid())
  itemId              String         @unique
  item                Item           @relation(fields: [itemId], references: [id])
  buyerId             String
  buyer               User           @relation(fields: [buyerId], references: [id])
  montoGanador        Decimal        @db.Decimal(12, 2)
  moneda              Currency
  comisiones          Decimal        @db.Decimal(12, 2) @default(0)
  costoEnvio          Decimal?       @db.Decimal(12, 2)
  retiraPersonalmente Boolean        @default(false)
  status              PurchaseStatus @default(pendiente_pago)
  multa               Decimal?       @db.Decimal(12, 2)
  multaAplicadaAt     DateTime?
  pagoVencimientoAt   DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@map("purchases")
}
